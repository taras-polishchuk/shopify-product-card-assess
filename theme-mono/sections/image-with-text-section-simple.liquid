{{ 'section-image-with-text-simple.css' | asset_url | stylesheet_tag }}

{% assign image_position = section.settings.position | default: false %}

<div
  class="image-with-text-simple"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px
  "
>
  <div class="image-with-text-simple__container {% if image_position %}image-with-text-simple__container--right{% endif %}">
    {% if section.settings.image != blank %}
      <div class="image-with-text-simple__image">
        <img
          src="{{ section.settings.image | image_url: width: 800, crop: 'center' }}"
          alt="{{ section.settings.image.alt | escape }}"
          height="400"
          width="400"
        >
      </div>
    {% endif %}

    <div class="image-with-text-simple__content">
      {% if section.settings.heading != blank %}
        <h2 class="image-with-text-simple__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="image-with-text-simple__text">{{ section.settings.text }}</p>
      {% endif %}

      {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}" class="image-with-text-simple__link">Learn more</a>
      {% endif %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Image with text (simple)",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "position",
      "label": "Image on the right",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Image with text (simple)",
      "category": "Image"
    }
  ]
}
{% endschema %}

{% assign btn_brightness = section.settings.primary_button_color | color_brightness %}
{% if btn_brightness > 128 %}
  {% assign btn_text_color = '#000000' %}
{% else %}
  {% assign btn_text_color = '#ffffff' %}
{% endif %}

<style>
  :root {
  --hero-banner-font-color: {{ section.settings.banner_heading_color }};
  --hero-banner-subheading-color: {{ section.settings.banner_subheading_color }};
  --primary-button-background-color: {{ section.settings.primary_button_color }};
  --primary-button-text-color: {{ btn_text_color }};
  }

  .hero-banner {
    position: relative;
    background-size: cover;
    background-position: center;
    height: 450px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-content h1 {
    color: var(--hero-banner-font-color);
    font-size: 3rem;
    margin-bottom: 10px;
  }

  .hero-content p {
    color: var(--hero-banner-subheading-color);
    font-size: 1.5rem;
    margin-bottom: 20px;
  }
  .btn {
    background-color: var(--primary-button-background-color);
    color: var(--primary-button-text-color);
    padding: 10px 20px;
    text-decoration: none;
    border-radius: 5px;
    font-weight: bold;
  }

  .btn:hover {
    opacity: 0.8;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
  }
</style>

<div
  class="hero-banner"
  style="
    background-image: url({{ section.settings.banner_image | image_url: height: 900, crop: 'center' }});
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px
  "
>
  <div class="hero-content">
    <h1>{{ section.settings.banner_heading }}</h1>
    <p>{{ section.settings.banner_subheading }}</p>
    {% if section.settings.banner_link != blank %}
      <a href="{{ section.settings.banner_link }}" class="btn">Learn More</a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Banner heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "color",
      "id": "banner_heading_color",
      "label": "Banner heading color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "banner_subheading",
      "label": "Banner subheading",
      "default": "Discover our latest products and offers"
    },
    {
      "type": "color",
      "id": "banner_subheading_color",
      "label": "Banner subheading color",
      "default": "#ffffff"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "color",
      "id": "primary_button_color",
      "label": "Primary button color",
      "default": "#492d2d"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}

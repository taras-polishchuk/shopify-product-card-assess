{{ 'section-collection-simple.css' | asset_url | stylesheet_tag }}

{% assign collection = collections[section.settings.collection] %}
{% assign products_to_show = section.settings.products_to_show %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --products-per-row: {{ section.settings.products_per_row }};
  }
{%- endstyle -%}

<div
  class="section-collection-simple"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <h2 class="section-collection-simple__title">{{ section.settings.section_title }}</h2>

  {% if collection %}
    <div class="section-collection-simple__grid">
      {% for product in collection.products limit: products_to_show %}
        <div class="section-collection-simple__item">
          <a href="{{ product.url }}">
            {% if product.featured_image %}
              <img
                class="section-collection-simple__item-image"
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                width="300"
                height="300"
                loading="lazy"
              >
            {% endif %}

            {% if product.compare_at_price > product.price %}
              <span class="badge price__badge-sale color-{{ settings.sale_badge_color_scheme }} section-collection-simple__bage">
                {{ 'products.product.on_sale' | t }}
              </span>
            {% endif %}

            {% unless product.available %}
              <span class="badge price__badge-sold-out color-{{ settings.sold_out_badge_color_scheme }} section-collection-simple__bage">
                {{ 'products.product.sold_out' | t }}
              </span>
            {% endunless %}

            <div class="section-collection-simple__item-info">
              <h3 class="section-collection-simple__item-title">{{ product.title }}</h3>
              <p class="section-collection-simple__item-price">{{ product.price | money }}</p>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p>Select a collection in the section settings.</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "limit": 1,
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Featured Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "default": 8,
      "min": 1,
      "max": 20,
      "step": 1
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "Products per row",
      "default": 4,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Simple",
      "category": "Featured"
    }
  ]
}
{% endschema %}

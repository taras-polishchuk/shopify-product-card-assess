{% comment %}
  Renders a swatch group (WAI-ARIA radio pattern) for a product card.

  Accepts:
    - product: {Object} Product Liquid object
    - option: {Object} Product option (must be color/colour)
    - section_id: {String} Parent section id
    - current_variant_id: {Number} Currently rendered variant id
{% endcomment %}

{%- liquid
  assign group_id = 'pcc-swatches-' | append: section_id | append: '-' | append: product.id
  assign _ = group_id
-%}

<fieldset class="pcc__swatches" data-pcc-swatches>
  <legend class="visually-hidden">
    {{ product.title | escape }} — {{ option.name | escape }}
  </legend>

  <ul
    class="pcc__swatch-list"
    role="radiogroup"
    aria-label="{{ product.title | escape }} — {{ option.name | escape }}"
    data-pcc-radiogroup
  >
    {%- assign selected_index = 0 -%}
    {%- for v in product.variants -%}
      {%- assign is_default = false -%}
      {%- if v.id == current_variant_id -%}
        {%- assign is_default = true -%}
        {%- assign _selected_index = forloop.index0 -%}
      {%- endif -%}
      {%- assign opt_value = v.options[0] -%}
      {%- assign swatch_color = nil -%}
      {%- assign swatch_image = nil -%}
      {%- assign _swatch_focal = nil -%}
      {%- comment -%}
        Resolve swatch visuals. Native Shopify swatch config takes precedence;
        otherwise fall back to option name color hint via a static map.
      {%- endcomment -%}
      {%- for opt in product.options_with_values -%}
        {%- if opt.name == option.name -%}
          {%- for val in opt.values -%}
            {%- if val == opt_value -%}
              {%- if val.swatch.image -%}
                {%- assign swatch_image = val.swatch.image -%}
              {%- elsif val.swatch.color -%}
                {%- assign swatch_color = 'rgb(' | append: val.swatch.color.rgb | append: ')' -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if swatch_color == nil and swatch_image == nil -%}
        {%- assign swatch_color = '#cccccc' -%}
      {%- endif -%}

      {%- assign is_available = v.available -%}

      <li class="pcc__swatch-item">
        <button
          type="button"
          class="pcc__swatch{% if is_default %} pcc__swatch--selected{% endif %}{% unless is_available %} pcc__swatch--unavailable{% endunless %}"
          role="radio"
          aria-checked="{% if is_default %}true{% else %}false{% endif %}"
          aria-label="{{ opt_value | escape }}{% unless is_available %} (unavailable){% endunless %}"
          tabindex="{% if is_default %}0{% else %}-1{% endif %}"
          data-variant-id="{{ v.id }}"
          data-option-value="{{ opt_value | escape }}"
          data-color-value="{% if swatch_color %}{{ swatch_color | escape }}{% endif %}"
          data-image-src="{% if swatch_image %}{{ swatch_image | image_url: width: 50 | escape }}{% endif %}"
          {% unless is_available %}aria-disabled="true"{% endunless %}
        >
          <span
            class="pcc__swatch-fill"
            {% if swatch_color %}
              style="background-color: {{ swatch_color }};"
            {% elsif swatch_image %}
              style="background-image: url('{{ swatch_image | image_url: width: 50 }}');"
            {% endif %}
            aria-hidden="true"
          ></span>
        </button>
      </li>
    {%- endfor -%}
  </ul>
</fieldset>